<mxfile host="app.diagrams.net" type="device">
  <diagram name="Diagrama de blocos" id="blocos-vending">
    <mxGraphModel dx="1050" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Vending Machine - Diagrama de blocos" style="text;html=1;align=center;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="360" y="10" width="380" height="30" as="geometry" />
        </mxCell>

        <!-- Entradas -->
        <mxCell id="in_coin" value="coin_in[1:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="in_sel" value="sel_item[1:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="in_confirm" value="confirm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="in_cancel" value="cancel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="in_clk" value="clk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="in_rst" value="rst" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="110" height="30" as="geometry" />
        </mxCell>

        <!-- Blocos do datapath -->
        <mxCell id="b_credit" value="credit_reg&#10;(registrador de credito, 8b)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="230" y="55" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="b_mem" value="memory&#10;(4 x 16: price, stock)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="230" y="330" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="b_cmp" value="comparator&#10;can_sell" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="470" y="150" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b_sub" value="subtractor&#10;change = credit - price" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="470" y="330" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Unidade de controle -->
        <mxCell id="b_fsm" value="control_unit&#10;&#10;FSM de Moore&#10;(6 estados)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="150" width="170" height="200" as="geometry" />
        </mxCell>

        <!-- Saidas -->
        <mxCell id="out_disp" value="dispense" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="960" y="120" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="out_change" value="change_out[7:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="960" y="170" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="out_err" value="error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="960" y="220" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="out_disp2" value="display[7:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="960" y="270" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="out_state" value="state_out[2:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="960" y="320" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- Arestas: entradas -> datapath -->
        <mxCell id="e1" value="coin_value" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="in_coin" target="b_credit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="addr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="in_sel" target="b_mem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- entradas de controle -> FSM -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="in_confirm" target="b_fsm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="in_cancel" target="b_fsm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="in_clk" target="b_fsm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;" edge="1" parent="1" source="in_rst" target="b_fsm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- datapath interno -->
        <mxCell id="e7" value="credit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_credit" target="b_cmp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="credit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_credit" target="b_sub">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="price, stock" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_mem" target="b_cmp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="price" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_mem" target="b_sub">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- datapath -> FSM e saidas -->
        <mxCell id="e11" value="can_sell" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_cmp" target="b_fsm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="change" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_sub" target="out_change">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FSM -> controle (feedback) -->
        <mxCell id="e13" value="credit_load / credit_clr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#d79b00;" edge="1" parent="1" source="b_fsm" target="b_credit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="mem_read / mem_write" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#d79b00;" edge="1" parent="1" source="b_fsm" target="b_mem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FSM -> saidas -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_fsm" target="out_disp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_fsm" target="out_err">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_fsm" target="out_state">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e18" value="display = credit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="b_credit" target="out_disp2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
